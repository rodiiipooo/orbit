# Core
SECRET_KEY=your-secret-key-change-in-production
DEBUG=false

# Database (set automatically by docker-compose)
DATABASE_URL=postgresql+asyncpg://orbit:orbit@localhost/orbitdb
REDIS_URL=redis://localhost:6379/0

# AI (text/content)
ANTHROPIC_API_KEY=sk-ant-...

# Image generation — local diffusion endpoint on Jarvis
# Point to your ComfyUI / Automatic1111 / Diffusers API server
# e.g. http://localhost:7860  or  http://jarvis.local:7860
LOCAL_DIFFUSION_URL=http://localhost:7860

# Video generation — InVideo (optional enterprise API key)
# Without this key, the API returns a pre-filled InVideo deep-link instead
INVIDEO_API_KEY=

# Email (Resend — resend.com/api-keys)
RESEND_API_KEY=re_...

# Social platforms (get from each platform's developer console)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_CLIENT_ID=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
